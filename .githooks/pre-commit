#!/usr/bin/env bash
# Reject staged files containing AI authorship attributions.
#
# Enable: git config core.hooksPath .githooks

set -e

# Collect staged files (added/modified/renamed/copied).
mapfile -t files < <(git diff --cached --name-only --diff-filter=ACMR)
[ ${#files[@]} -eq 0 ] && exit 0

patterns=(
  'Co-Authored-By:[[:space:]]*[^<]*(Claude|Anthropic|Copilot|GPT|OpenAI|Gemini|Bard|Cursor|Codeium)'
  '(Generated|Written|Authored|Produced)[[:space:]]+with[[:space:]]+(Claude|Anthropic|Copilot|ChatGPT|GPT|OpenAI|Gemini|Cursor|AI)'
  'claude\.ai/code'
  '🤖[[:space:]]*Generated'
)

violations=0

for f in "${files[@]}"; do
  # Skip binary files and this hook itself (which legitimately names these patterns).
  [ ! -f "$f" ] && continue
  case "$f" in
    .githooks/*) continue ;;
  esac
  if file --mime "$f" 2>/dev/null | grep -q 'charset=binary'; then
    continue
  fi

  for pattern in "${patterns[@]}"; do
    if grep -nHiE "$pattern" "$f" >/dev/null 2>&1; then
      echo "ERROR: $f contains an AI authorship attribution:" >&2
      grep -nHiE "$pattern" "$f" >&2
      echo "" >&2
      violations=$((violations + 1))
    fi
  done
done

if [ "$violations" -gt 0 ]; then
  echo "Remove AI attribution markers from staged files before committing." >&2
  exit 1
fi

exit 0
